# === Line endings ===
# All text files use LF (project deploys to Linux containers)
* text=auto eol=lf
# Explicit text types (auto-detect can miss some)
*.py text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.txt text eol=lf
data/function_2.csv filter=lfs diff=lfs merge=lfs -text
*.tsv text eol=lf
*.fasta text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.json text eol=lf
*.rst text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
# === Binary files (no text diffs) ===
# Model weights
*.pt binary
*.pth binary
*.h5 binary
*.ckpt binary
*.pkl binary
*.onnx binary
# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.pdf binary
# Office
*.xlsx binary
*.xls binary
*.pptx binary
*.docx binary
# Archives
*.zip binary
*.tar binary
*.gz binary
*.bz2 binary
*.7z binary
# === Generated / lock files ===
uv.lock binary linguist-generated=true
# === Linguist overrides ===
# BepiPred-3.0 cloned reference repo — not our code
tools/BepiPred-3.0/repo/** linguist-vendored
# Generated HTML output (22 MB file skewing language stats)
tools/BepiPred-3.0/repo/misc/biolib_bepipred3/output_directory/*.html linguist-generated=true
tools/BepiPred-3.0/repo/test_output/*.html linguist-generated=true
output3/pipeline.db filter=lfs diff=lfs merge=lfs -text
output3/pipeline.db !text !filter !merge !diff
